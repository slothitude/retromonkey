# RetroMonkey — primary store
retromonkey.com.au {
    reverse_proxy retromonkey:5000

    encode gzip

    # Static files with long cache
    @static path /static/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Security headers
    header {
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }
}

www.retromonkey.com.au {
    redir https://retromonkey.com.au{uri} permanent
}

# Future stores — uncomment and configure when adding a new store:
# techtreasure.com.au {
#     reverse_proxy techtreasure:5000
#     encode gzip
